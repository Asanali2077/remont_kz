// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  COMPANY
}

enum ServiceCategory {
  AUTOMOBILES
  REAL_ESTATE
  OTHER
}

enum RequestStatus {
  NEW
  ACCEPTED
  IN_PROGRESS
  COMPLETED
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  role          UserRole
  name          String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  services           Service[]
  clientRequests     Request[]  @relation("ClientRequests")
  companyRequests    Request[]  @relation("CompanyRequests")
  sentMessages       Message[]  @relation("SentMessages")
  receivedMessages   Message[]  @relation("ReceivedMessages")

  @@index([email])
  @@index([role])
}

model Service {
  id                String          @id @default(uuid())
  name              String
  category          ServiceCategory
  description       String          @db.Text
  priceFrom         Float
  priceTo           Float
  active            Boolean         @default(true)
  city              String?
  rating            Float?
  licensed          Boolean          @default(false)
  availabilityDays  Int?
  urgency           String?         // "low" | "medium" | "high"
  tags              String[]         @default([])
  customAttributes  Json?           // Record<string, string>
  companyId         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  company           User            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  images            ServiceImage[]
  requests          Request[]

  @@index([companyId])
  @@index([category])
  @@index([city])
  @@index([active])
}

model ServiceImage {
  id        String   @id @default(uuid())
  serviceId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model Request {
  id          String        @id @default(uuid())
  clientId    String
  serviceId   String?
  companyId   String?
  description String        @db.Text
  category    ServiceCategory?
  city        String?
  imageUrl    String?
  status      RequestStatus @default(NEW)
  rating      Int?
  budgetFrom  Float?
  budgetTo    Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  client      User          @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  service     Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  company     User?         @relation("CompanyRequests", fields: [companyId], references: [id], onDelete: SetNull)
  messages    Message[]

  @@index([clientId])
  @@index([companyId])
  @@index([serviceId])
  @@index([status])
  @@index([category])
  @@index([city])
}

model Message {
  id          String      @id @default(uuid())
  requestId   String?
  senderId    String
  receiverId  String
  content     String      @db.Text
  type        MessageType @default(TEXT)
  imageUrl    String?
  audioUrl    String?
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())

  // Relations
  request     Request?    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender      User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}
