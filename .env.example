# ── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/remont_kz"

# ── Auth ──────────────────────────────────────────────
JWT_SECRET="your-strong-random-secret-min-32-chars"
# JWT_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="/api"

# ── AI (Anthropic Claude) ─────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-6"  # override model version if needed

# ── File Storage (optional S3/R2 — uses local disk if not set) ──
# S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
# S3_BUCKET="remont-uploads"
# S3_REGION="auto"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_PUBLIC_URL="https://pub-<hash>.r2.dev"  # public CDN URL

# ── CORS ──────────────────────────────────────────────
# CORS_ORIGIN="https://yourdomain.com"

# ── SMTP (Email sending) ──────────────────────────────
# Option A: Mailtrap (free testing inbox) — https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
SMTP_FROM="Remont.kz <noreply@remont.kz>"

# Option B: Gmail (App Password required)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_16_char_app_password
